<Window x:Class="UnRARer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UnRARer"
        mc:Ignorable="d"
        Title="UnRARer - Extract RAR Archive"
        Height="300" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Archive file label -->
        <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14"
                   x:Name="FileInfoLabel" Text="Archive: (none selected)"
                   Margin="0,0,0,10"/>

        <!-- Destination label -->
        <TextBlock Grid.Row="1" Text="Extract to:" Margin="0,0,0,5"/>

        <!-- Destination path + Browse -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="DestinationTextBox"
                     VerticalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="Browse..." Width="80" Height="28"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- Password label -->
        <TextBlock Grid.Row="3" Text="Password (if required):" Margin="0,0,0,5"/>

        <!-- Password field -->
        <PasswordBox Grid.Row="4" x:Name="PasswordBox"
                     Height="28" Margin="0,0,0,15"/>

        <!-- Status label -->
        <TextBlock Grid.Row="5" x:Name="StatusLabel" Text=""
                   Foreground="Gray" Margin="0,0,0,10"/>

        <!-- Progress bar (hidden by default) -->
        <ProgressBar Grid.Row="6" x:Name="ProgressBar"
                     IsIndeterminate="True" Height="20"
                     Visibility="Collapsed" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Extract" Width="100" Height="32"
                    x:Name="ExtractButton" Click="ExtractButton_Click"
                    IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="100" Height="32"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
